# Hoist only sharp's native binaries (@img/sharp-* + libvips) to the top-level
# node_modules, leaving pnpm's strict linking (and the slim image) intact for
# everything else. sharp loads them via a computed `require('@img/sharp-' + platform)`
# the Next standalone tracer can't follow, so they're force-included via
# outputFileTracingIncludes (next.config.ts) — which needs them at ./node_modules/@img,
# not buried in pnpm's virtual store.
public-hoist-pattern[]=@img/*
