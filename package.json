{
  "name": "bragbit",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "DATABASE_URL=postgres://bragbit:bragbit@localhost:5433/bragbit BETTER_AUTH_SECRET=0123456789abcdef0123456789abcdef vitest run",
    "test:db:coverage": "DATABASE_URL=postgres://bragbit:bragbit@localhost:5433/bragbit BETTER_AUTH_SECRET=0123456789abcdef0123456789abcdef vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:setup:solo": "INSTANCE_MODE=private-solo SETUP_PORT=3100 playwright test -c playwright.setup.config.ts",
    "test:e2e:setup:org": "INSTANCE_MODE=private-org SETUP_PORT=3101 playwright test -c playwright.setup.config.ts",
    "test:e2e:setup": "node scripts/e2e-setup-db.mjs && pnpm test:e2e:setup:solo && pnpm test:e2e:setup:org",
    "size": "size-limit",
    "dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "node scripts/seed-demo.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1095.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-dialog": "^1.1.22",
    "@radix-ui/react-label": "^2.1.14",
    "@radix-ui/react-slot": "^1.3.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "better-auth": "^1.6.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.26.0",
    "mcp-handler": "^1.1.0",
    "next": "16.2.11",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6",
    "vitest": "^4.1.10"
  }
}
