{
  "name": "bragbit",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db": "DATABASE_URL=postgres://bragbit:bragbit@localhost:5433/bragbit BETTER_AUTH_SECRET=0123456789abcdef0123456789abcdef vitest run",
    "test:db:coverage": "DATABASE_URL=postgres://bragbit:bragbit@localhost:5433/bragbit BETTER_AUTH_SECRET=0123456789abcdef0123456789abcdef vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:setup:solo": "INSTANCE_MODE=private-solo SETUP_PORT=3100 playwright test -c playwright.setup.config.ts",
    "test:e2e:setup:org": "INSTANCE_MODE=private-org SETUP_PORT=3101 playwright test -c playwright.setup.config.ts",
    "test:e2e:setup": "node scripts/e2e-setup-db.mjs && pnpm test:e2e:setup:solo && pnpm test:e2e:setup:org",
    "size": "size-limit",
    "dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:demo": "node scripts/seed-demo.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "better-auth": "^1.6.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "lefthook": "^2.1.9",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-67mh-4wv8-2f99"
      ]
    }
  }
}
