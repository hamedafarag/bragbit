# ─────────────────────────────────────────────────────────────────────────────
# BragBit — environment configuration
#
# Copy to `.env` and fill in. Every variable is validated at boot by
# src/lib/env.ts, so a misconfigured instance fails fast with a clear error.
#
# This file serves two paths:
#   • Local dev      — values point at the dev stack (docker-compose.dev.yml:
#                      Postgres, Mailpit, MinIO).
#   • Docker Compose — `docker compose up` reads this file for the app's secrets
#                      and config, and wires DATABASE_URL → the bundled `postgres`
#                      service and STORAGE_DIR → a named volume automatically, so
#                      you only set INSTANCE_MODE, APP_URL, BETTER_AUTH_SECRET, and
#                      the SMTP block. See docs/self-hosting/.
# ─────────────────────────────────────────────────────────────────────────────

# ── Instance shape ───────────────────────────────────────────────────────────
# Which deployment mode this instance runs in:
#   private-org   a company self-hosting one organization (setup wizard + invites)
#   private-solo  a freelancer self-hosting one personal workspace
#   hosted        a shared multi-tenant instance (open signup + user-created orgs)
# On first run (private modes) every route redirects to the /setup wizard until
# the owner + first workspace exist; afterwards the wizard is disabled.
INSTANCE_MODE=private-solo

# Optional shared secret that gates the first-run /setup wizard (private modes).
# Set it to keep anyone but you out of the wizard if the URL is public before setup.
# SETUP_TOKEN=

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# The instance's public URL — used in emails, share links, and auth callbacks.
# In production set this to the real origin (e.g. https://brag.example.com). Use
# https there: Better Auth derives the session-cookie `Secure` flag from this
# scheme, so an http value behind a TLS proxy ships cookies without `Secure`.
APP_URL=http://localhost:3000

# PostgreSQL connection string (required). Under Docker Compose this is set for
# you (→ the bundled `postgres` service); for local dev it points at the dev stack.
DATABASE_URL=postgres://bragbit:bragbit@localhost:5432/bragbit
# Host port for the dev-stack Postgres (docker-compose.dev.yml). Bump to e.g. 5433
# if 5432 is already in use, and match DATABASE_URL's port to it.
# POSTGRES_PORT=5432

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
# REQUIRED. Generate a real value for any non-local instance:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret
# Defaults to APP_URL when unset.
# BETTER_AUTH_URL=http://localhost:3000

# ── Email (SMTP) — required for verification, invites, reset, reminders ───────
# In local dev, point these at Mailpit (docker-compose.dev.yml). In production use
# a real SMTP relay — the app sends verification, invitation, password-reset, and
# weekly-reminder mail, so a working sender is needed end to end.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM=BragBit <no-reply@bragbit.local>

# ── Storage adapter ──────────────────────────────────────────────────────────
# local = disk (STORAGE_DIR);  s3 = any S3-compatible endpoint (MinIO / R2 / S3)
# Under Docker Compose with local storage, STORAGE_DIR is set to a named volume
# for you. For S3 set STORAGE_DRIVER=s3 + the S3_* block, then bring up the bundled
# MinIO with:  docker compose --profile minio up -d
STORAGE_DRIVER=local
STORAGE_DIR=./.data/uploads
# S3_ENDPOINT=http://localhost:9000    # http://minio:9000 inside Docker Compose
# S3_REGION=us-east-1
# S3_BUCKET=bragbit
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true     # required for MinIO

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# Set both the id and secret for a provider to enable it; the sign-in page then
# shows its button. In the private modes OAuth only signs in already-provisioned
# accounts (it links to an existing email-verified account and will not create a
# new one). Register these callback (redirect) URLs with the provider:
#   GitHub →  {APP_URL}/api/auth/callback/github
#   Google →  {APP_URL}/api/auth/callback/google
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Uploads ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25

# ── Hosted-mode abuse controls (INSTANCE_MODE=hosted) ────────────────────────
BLOCK_DISPOSABLE_EMAIL=true
WORKSPACE_QUOTA_MB=2048

# ── Reminder cron ────────────────────────────────────────────────────────────
# The standalone (Docker) server schedules weekly reminders itself, in-process —
# no external cron needed. CRON_SECRET is only for the serverless fallback: it
# guards POST /api/cron/reminders so an external scheduler can trigger a send.
# Generate with: openssl rand -base64 32
# CRON_SECRET=

# ── Timing & limits (optional; defaults match shipped behaviour) ─────────────
# Tunable so the time-bound flows can be exercised without waiting out the
# production defaults — e.g. set a short INVITATION_TTL_DAYS to test expiry, or
# RATE_LIMIT_ENABLED=true to exercise the brute-force limiter in dev.
# INVITATION_TTL_DAYS=7         # invite link lifetime
# AUTH_TOKEN_TTL_MINUTES=60     # verification + password-reset link lifetime
# REMINDER_HOUR=9               # local hour (0–23) weekly reminders fire
# REMINDER_DEDUP_HOURS=20       # re-send suppression window
# RATE_LIMIT_ENABLED=           # unset → on in production, off in dev; true/false forces it

# ── Docker Compose knobs (docker-compose.yml) ────────────────────────────────
# Read by docker-compose.yml itself, not by the app. Defaults shown.
# POSTGRES_PASSWORD=bragbit     # password for the bundled Postgres + DATABASE_URL
# APP_PORT=3000                 # host port mapped to the app container
