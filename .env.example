# ─────────────────────────────────────────────────────────────────────────────
# BragBit — environment configuration
# Copy to `.env` and fill in. Every variable is validated at boot by
# src/lib/env.ts, so a misconfigured instance fails fast with a clear error.
# ─────────────────────────────────────────────────────────────────────────────

# ── Instance shape ───────────────────────────────────────────────────────────
# Which deployment mode this instance runs in:
#   private-org   a company self-hosting one organization (setup wizard + invites)
#   private-solo  a freelancer self-hosting one personal workspace
#   hosted        a shared multi-tenant instance (open signup + user-created orgs)
INSTANCE_MODE=private-solo

# Optional shared secret that gates the first-run /setup wizard (private modes).
# SETUP_TOKEN=

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL connection string (required).
DATABASE_URL=postgres://bragbit:bragbit@localhost:5432/bragbit
# Host port for the dev-stack Postgres (docker-compose.dev.yml). Bump to e.g. 5433
# if 5432 is already in use, and match DATABASE_URL's port to it.
# POSTGRES_PORT=5432

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret
# Defaults to APP_URL when unset.
# BETTER_AUTH_URL=http://localhost:3000

# ── Email (SMTP) — required for verification, invites, reset, reminders ───────
# In local dev, point these at Mailpit (docker-compose.dev.yml).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM=BragBit <no-reply@bragbit.local>

# ── Storage adapter ──────────────────────────────────────────────────────────
# local = disk (STORAGE_DIR);  s3 = any S3-compatible endpoint (MinIO / R2 / S3)
STORAGE_DRIVER=local
STORAGE_DIR=./.data/uploads
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=bragbit
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true     # required for MinIO

# ── OAuth (optional) ─────────────────────────────────────────────────────────
# In private modes OAuth only signs in already-provisioned accounts.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Uploads ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=25

# ── Hosted-mode abuse controls (INSTANCE_MODE=hosted) ────────────────────────
BLOCK_DISPOSABLE_EMAIL=true
WORKSPACE_QUOTA_MB=2048

# ── Reminder cron (external-cron fallback) ───────────────────────────────────
# Shared secret required to call the reminder route handler.
# CRON_SECRET=
